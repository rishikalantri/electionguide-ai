# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Required. The chatbot will not work without this key.
GEMINI_API_KEY=

# ─── Google Cloud Platform ────────────────────────────────────────────────────
# Your GCP project ID. Used by Firestore and Cloud SDKs when running locally
# (Cloud Run detects the project automatically from the metadata server).
GOOGLE_CLOUD_PROJECT_ID=

# ─── Local development only ───────────────────────────────────────────────────
# Absolute path to a service account JSON file stored in secrets/.
# The Google Cloud SDK reads this env var automatically — no code parsing needed.
#
# Example (Mac/Linux):
#   GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/ElectionGuide-AI/backend/secrets/sa-key.json
#
# On Cloud Run: leave this BLANK. Cloud Run injects credentials from the
# attached service account via the GCE metadata server. Setting this on Cloud
# Run would override ADC and may cause auth failures.
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Firestore ────────────────────────────────────────────────────────────────
# Leave blank or set to (default) to use the default Firestore database.
# Set to a custom name only if you created a named database in GCP Console.
FIRESTORE_DATABASE_ID=(default)

# ─── Feature flags ────────────────────────────────────────────────────────────
# These do not enable/disable the endpoints themselves but can be read by
# future middleware to skip GCP calls when credentials are not present.
TRANSLATE_ENABLED=true
TTS_ENABLED=true
